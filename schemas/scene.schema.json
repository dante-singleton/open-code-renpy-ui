          "type": "object",
          "properties": {
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            },
            "zoom": {
              "type": "number",
              "exclusiveMinimum": true,
              "minimum": 0
            }
          },
          "required": ["x", "y", "zoom"],
          "additionalProperties": false
        },
        "notes": {
          "type": "string"
        }
      },
      "required": ["specVersion", "id", "label", "title", "entryNodeId", "nodes"],
      "additionalProperties": false
    }
  },
  "$schema": "https://json-schema.org/draft/2019-09/schema#"
}
