{
  "specVersion": "1.0.0",
  "id": "01HYZSCENE_DOOR",
  "label": "door",
  "title": "The Locked Door",
  "entryNodeId": "n_start",
  "nodes": [
    { "id": "n_start", "type": "start", "position": { "x": 0, "y": 0 } },
    {
      "id": "n_if",
