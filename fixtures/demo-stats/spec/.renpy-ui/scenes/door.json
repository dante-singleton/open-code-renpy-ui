    { "id": "e5", "source": "n_if", "sourceHandle": "branch:b_loved", "target": "n_loved_say" },
    { "id": "e6", "source": "n_loved_say", "target": "n_python" },
    { "id": "e7", "source": "n_if", "sourceHandle": "branch:b_else", "target": "n_else_say" },
