    },
    {
      "id": "n_strong_say",
      "type": "narration",
      "position": { "x": 400, "y": -120 },
      "text": "You force the door open."
    },
    {
      "id": "n_strong_dec",
      "type": "increment",
      "position": { "x": 600, "y": -120 },
